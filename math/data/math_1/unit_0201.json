{
  "curriculum": "중1 수학",
  "unit_id": "0201",
  "title": "문자와 식",
  "lessons": [
    {
      "lesson_id": "0201-01",
      "title": "문자의 사용",
      "goal": "문자를 사용해 수량 관계를 나타낸다.",
      "steps": [
        {
          "step": 1,
          "type": "recall",
          "title": "말을 식으로",
          "prompt": "사과가 x개 있고 3개 더 있으면 모두 몇 개일까?",
          "reveal_answer": "x+3"
        },
        {
          "step": 2,
          "type": "concept",
          "title": "핵심 개념",
          "concepts": [
            "문자는 아직 정해지지 않은 수를 나타낸다.",
            "문자를 쓰면 규칙과 관계를 간단히 나타낼 수 있다."
          ]
        },
        {
          "step": 3,
          "type": "pattern",
          "title": "표현 익히기",
          "examples": [
            {
              "sentence": "어떤 수 a의 3배",
              "expression": "3a"
            },
            {
              "sentence": "x보다 5 큰 수",
              "expression": "x+5"
            },
            {
              "sentence": "y를 2로 나눈 수",
              "expression": "y/2"
            }
          ]
        },
        {
          "step": 4,
          "type": "guided_example",
          "title": "같이 바꾸기",
          "problem": "민수의 나이가 x살일 때, 3년 후 나이와 2배 나이를 식으로 나타내자.",
          "hint": "시간 변화는 더하기, 몇 배는 곱하기.",
          "solution": {
            "3년 후": "x+3",
            "2배": "2x"
          }
        },
        {
          "step": 5,
          "type": "quiz",
          "title": "확인",
          "items": [
            {
              "q": "'a의 5배보다 2 큰 수'를 식으로 쓰면?",
              "choices": [
                "5a+2",
                "a+5+2",
                "5(a+2)"
              ],
              "answer": 0,
              "feedback_correct": "5배를 먼저 만들고 2를 더해.",
              "feedback_wrong": "말의 순서를 잘 보자."
            }
          ]
        }
      ]
    },
    {
      "lesson_id": "0201-02",
      "title": "대입과 식의 값",
      "goal": "문자에 수를 대입해 식의 값을 구한다.",
      "steps": [
        {
          "step": 1,
          "type": "recall",
          "title": "숫자 넣기",
          "prompt": "x+4에서 x=3이면 값은?",
          "reveal_answer": "7"
        },
        {
          "step": 2,
          "type": "concept",
          "title": "핵심 개념",
          "concepts": [
            "문자에 주어진 수를 넣어 계산한 값을 식의 값이라고 한다."
          ],
          "misconceptions": [
            "대입 후 괄호를 생략하며 부호 실수"
          ]
        },
        {
          "step": 3,
          "type": "pattern",
          "title": "대입 연습",
          "examples": [
            {
              "expr": "2x+1, x=4",
              "value": "9"
            },
            {
              "expr": "a-b, a=3, b=5",
              "value": "-2"
            }
          ]
        },
        {
          "step": 4,
          "type": "guided_example",
          "title": "같이 계산하기",
          "problem": "3x-2에서 x=-1일 때 식의 값을 구하자.",
          "hint": "음수를 넣을 때는 괄호로 묶자.",
          "solution": "3(-1)-2 = -5"
        },
        {
          "step": 5,
          "type": "quiz",
          "title": "바로 확인",
          "items": [
            {
              "q": "2a+3에서 a=5일 때 값은?",
              "choices": [
                "10",
                "13",
                "8"
              ],
              "answer": 1,
              "feedback_correct": "2×5+3=13",
              "feedback_wrong": "곱셈 먼저 계산해."
            }
          ]
        }
      ]
    },
    {
      "lesson_id": "0201-03",
      "title": "일차식의 계산",
      "goal": "동류항을 모아 일차식을 간단히 계산한다.",
      "steps": [
        {
          "step": 1,
          "type": "recall",
          "title": "같은 글자끼리",
          "prompt": "3x와 2x는 더할 수 있을까?",
          "reveal_answer": "가능, 5x"
        },
        {
          "step": 2,
          "type": "concept",
          "title": "핵심 개념",
          "concepts": [
            "문자와 차수가 같은 항을 동류항이라고 한다.",
            "동류항끼리만 더하고 뺄 수 있다."
          ]
        },
        {
          "step": 3,
          "type": "pattern",
          "title": "정리하는 법",
          "examples": [
            {
              "expr": "3x+2x",
              "value": "5x"
            },
            {
              "expr": "4a-a+3",
              "value": "3a+3"
            },
            {
              "expr": "2x+3y-x",
              "value": "x+3y"
            }
          ]
        },
        {
          "step": 4,
          "type": "guided_example",
          "title": "같이 계산하기",
          "problem": "5x+2-3x+7을 간단히 하자.",
          "hint": "x항끼리, 숫자끼리 따로 모아.",
          "solution": "2x+9"
        },
        {
          "step": 5,
          "type": "quiz",
          "title": "확인 퀴즈",
          "items": [
            {
              "q": "3a+5-2a의 계산 결과는?",
              "choices": [
                "a+5",
                "5a-2",
                "a+3"
              ],
              "answer": 0,
              "feedback_correct": "3a-2a=a",
              "feedback_wrong": "문자항과 숫자항을 따로 보자."
            }
          ]
        }
      ]
    }
  ]
}