        {
          "step": 2,
          "type": "concept",
          "title": "핵심 개념",
          "concepts": [
            "점: 위치만 나타냄",
            "직선: 양쪽 끝없이 곧게 뻗음",
            "반직선: 한쪽으로만 끝없이 뻗음",
            "선분: 양 끝이 정해진 부분",
            "각: 한 점에서 나온 두 반직선이 이루는 도형"
          ]
        },
        {
          "step": 3,
          "type": "pattern",
          "title": "표현 익히기",
          "examples": [
