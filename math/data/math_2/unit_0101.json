{
  "curriculum": "중2 수학",
  "unit_id": "0101",
  "title": "유리수와 소수",
  "lessons": [
    {
      "lesson_id": "0101-01",
      "title": "유리수와 순환소수",
      "goal": "유리수를 소수로 나타내고, 유한소수와 순환소수를 구분한다.",
      "steps": [
        {
          "step": 1,
          "type": "recall",
          "title": "분수를 소수로 바꾸기",
          "prompt": "1/2, 1/3을 소수로 나타내면 어떻게 될까?",
          "reveal_answer": "1/2 = 0.5, 1/3 = 0.333..."
        },
        {
          "step": 2,
          "type": "concept",
          "title": "핵심 개념",
          "concepts": [
            "유리수는 정수 또는 분수로 나타낼 수 있는 수이다.",
            "유리수를 소수로 나타내면 유한소수 또는 순환소수가 된다.",
            "순환소수는 같은 숫자나 숫자 묶음이 끝없이 반복되는 소수이다."
          ],
          "misconceptions": [
            "끝없이 이어지는 소수는 모두 무리수라고 생각함",
            "순환되는 부분을 찾지 못함"
          ]
        },
        {
          "step": 3,
          "type": "pattern",
          "title": "구별하기",
          "examples": [
            {
              "value": "0.25",
              "type": "유한소수"
            },
            {
              "value": "0.333...",
              "type": "순환소수"
            },
            {
              "value": "0.272727...",
              "type": "순환소수"
            }
          ]
        },
        {
          "step": 4,
          "type": "guided_example",
          "title": "같이 해보기",
          "problem": "5/8, 2/3, 7/11을 소수로 나타내고 종류를 말해보자.",
          "hint": "나누어 보면 끝나는지, 같은 부분이 반복되는지 보자.",
          "solution": {
            "5/8": "0.625, 유한소수",
            "2/3": "0.666..., 순환소수",
            "7/11": "0.636363..., 순환소수"
          }
        },
        {
          "step": 5,
          "type": "quiz",
          "title": "확인 퀴즈",
          "items": [
            {
              "q": "다음 중 순환소수는?",
              "choices": [
                "0.4",
                "0.121212...",
                "0.375"
              ],
              "answer": 1,
              "feedback_correct": "12가 반복되고 있어.",
              "feedback_wrong": "반복되는 숫자 묶음이 있는지 보자."
            },
            {
              "q": "다음 중 유한소수는?",
              "choices": [
                "1/3",
                "5/6",
                "3/4"
              ],
              "answer": 2,
              "feedback_correct": "3/4 = 0.75로 끝나.",
              "feedback_wrong": "직접 소수로 바꿔 보자."
            }
          ]
        }
      ]
    },
    {
      "lesson_id": "0101-02",
      "title": "순환소수의 표현",
      "goal": "순환마디를 찾고 순환소수를 간단히 나타낸다.",
      "steps": [
        {
          "step": 1,
          "type": "recall",
          "title": "반복되는 부분 찾기",
          "prompt": "0.777...에서 반복되는 숫자는 무엇일까?",
          "reveal_answer": "7"
        },
        {
          "step": 2,
          "type": "concept",
          "title": "핵심 개념",
          "concepts": [
            "순환소수에서 반복되는 부분을 순환마디라고 한다.",
            "순환마디 위에 점을 찍어 간단히 나타낼 수 있다."
          ],
          "misconceptions": [
            "반복되지 않는 앞부분까지 순환마디로 생각함"
          ]
        },
        {
          "step": 3,
          "type": "pattern",
          "title": "순환마디 찾기",
          "examples": [
            {
              "value": "0.333...",
              "period": "3"
            },
            {
              "value": "0.272727...",
              "period": "27"
            },
            {
              "value": "0.1666...",
              "period": "6"
            }
          ]
        },
        {
          "step": 4,
          "type": "guided_example",
          "title": "같이 찾기",
          "problem": "0.454545..., 0.12222...의 순환마디를 찾아보자.",
          "hint": "처음부터 반복되는지, 중간부터 반복되는지 나눠 보자.",
          "solution": {
            "0.454545...": "순환마디 45",
            "0.12222...": "순환마디 2"
          }
        },
        {
          "step": 5,
          "type": "quiz",
          "title": "기초 확인",
          "items": [
            {
              "q": "0.818181...의 순환마디는?",
              "choices": [
                "8",
                "81",
                "18"
              ],
              "answer": 1,
              "feedback_correct": "81이 반복돼.",
              "feedback_wrong": "반복되는 묶음을 보자."
            }
          ]
        }
      ]
    },
    {
      "lesson_id": "0101-03",
      "title": "순환소수를 분수로 나타내기",
      "goal": "순환소수를 분수로 바꾼다.",
      "steps": [
        {
          "step": 1,
          "type": "recall",
          "title": "식 세우기",
          "prompt": "x = 0.333...이라고 놓으면 10x는 얼마일까?",
          "reveal_answer": "10x = 3.333..."
        },
        {
          "step": 2,
          "type": "concept",
          "title": "핵심 개념",
          "concepts": [
            "순환소수를 문자로 놓고 자리수를 맞춰 빼면 분수로 나타낼 수 있다."
          ],
          "misconceptions": [
            "반복 자릿수만큼 곱하지 않음",
            "소수점을 옮긴 뒤 빼기를 잘못함"
          ]
        },
        {
          "step": 3,
          "type": "pattern",
          "title": "풀이 흐름",
          "examples": [
            {
              "value": "0.333...",
              "flow": "x=0.333... → 10x=3.333... → 9x=3 → x=1/3"
            },
            {
              "value": "0.272727...",
              "flow": "x=0.272727... → 100x=27.272727... → 99x=27 → x=27/99=3/11"
            }
          ]
        },
        {
          "step": 4,
          "type": "guided_example",
          "title": "같이 바꾸기",
          "problem": "0.666...을 분수로 나타내자.",
          "hint": "x로 놓고 10배한 뒤 빼 보자.",
          "solution": "x=0.666... → 10x=6.666... → 9x=6 → x=6/9=2/3"
        },
        {
          "step": 5,
          "type": "quiz",
          "title": "마무리 퀴즈",
          "items": [
            {
              "q": "0.777...을 분수로 나타내면?",
              "choices": [
                "7/10",
                "7/9",
                "9/7"
              ],
              "answer": 1,
              "feedback_correct": "x=0.777...으로 두고 계산하면 7/9야.",
              "feedback_wrong": "순환소수는 분수로 바꿀 수 있어."
            }
          ]
        }
      ]
    }
  ]
}