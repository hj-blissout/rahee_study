{
  "curriculum": "중2 수학",
  "unit_id": "0201",
  "title": "단항식의 계산",
  "lessons": [
    {
      "lesson_id": "0201-01",
      "title": "지수법칙",
      "goal": "같은 밑의 거듭제곱의 곱셈과 나눗셈을 계산한다.",
      "steps": [
        {
          "step": 1,
          "type": "recall",
          "title": "거듭제곱 복습",
          "prompt": "a² × a³을 풀어서 쓰면 어떻게 될까?",
          "reveal_answer": "a×a × a×a×a = a⁵"
        },
        {
          "step": 2,
          "type": "concept",
          "title": "핵심 개념",
          "concepts": [
            "같은 밑의 거듭제곱의 곱셈은 지수를 더한다.",
            "같은 밑의 거듭제곱의 나눗셈은 지수를 뺀다.",
            "거듭제곱의 거듭제곱은 지수를 곱한다."
          ],
          "misconceptions": [
            "a² × a³을 a⁶으로 계산함",
            "나눗셈에서도 지수를 더함"
          ]
        },
        {
          "step": 3,
          "type": "pattern",
          "title": "규칙 익히기",
          "examples": [
            {
              "expr": "x²×x⁴",
              "value": "x⁶"
            },
            {
              "expr": "a⁵÷a²",
              "value": "a³"
            },
            {
              "expr": "(b²)³",
              "value": "b⁶"
            }
          ]
        },
        {
          "step": 4,
          "type": "guided_example",
          "title": "같이 계산하기",
          "problem": "y³×y², c⁷÷c³, (m²)⁴를 계산해보자.",
          "hint": "곱셈은 더하기, 나눗셈은 빼기, 괄호는 곱하기.",
          "solution": {
            "y³×y²": "y⁵",
            "c⁷÷c³": "c⁴",
            "(m²)⁴": "m⁸"
          }
        },
        {
          "step": 5,
          "type": "quiz",
          "title": "확인 퀴즈",
          "items": [
            {
              "q": "a⁴×a³의 값은?",
              "choices": [
                "a⁷",
                "a¹²",
                "a"
              ],
              "answer": 0,
              "feedback_correct": "같은 밑의 곱셈은 지수를 더해.",
              "feedback_wrong": "밑은 그대로 두고 지수만 더하자."
            },
            {
              "q": "x⁶÷x²의 값은?",
              "choices": [
                "x³",
                "x⁴",
                "x⁸"
              ],
              "answer": 1,
              "feedback_correct": "나눗셈은 지수를 빼면 돼.",
              "feedback_wrong": "6-2를 해보자."
            }
          ]
        }
      ]
    },
    {
      "lesson_id": "0201-02",
      "title": "단항식의 곱셈과 나눗셈",
      "goal": "단항식끼리의 곱셈과 나눗셈을 계산한다.",
      "steps": [
        {
          "step": 1,
          "type": "recall",
          "title": "숫자와 문자 따로 보기",
          "prompt": "2a × 3a를 계산하면?",
          "reveal_answer": "6a²"
        },
        {
          "step": 2,
          "type": "concept",
          "title": "핵심 개념",
          "concepts": [
            "단항식의 곱셈은 계수끼리 곱하고, 같은 문자는 지수법칙을 이용한다.",
            "단항식의 나눗셈은 계수끼리 나누고, 같은 문자는 지수를 뺀다."
          ],
          "misconceptions": [
            "계수와 문자를 섞어서 계산함",
            "문자의 차수를 더하거나 빼지 않음"
          ]
        },
        {
          "step": 3,
          "type": "pattern",
          "title": "계산 흐름",
          "examples": [
            {
              "expr": "2a×3a²",
              "value": "6a³"
            },
            {
              "expr": "4x²y×3xy",
              "value": "12x³y²"
            },
            {
              "expr": "12a³b÷3ab",
              "value": "4a²"
            }
          ]
        },
        {
          "step": 4,
          "type": "guided_example",
          "title": "같이 풀기",
          "problem": "5x² × 2x³, 18a²b ÷ 3ab를 계산하자.",
          "hint": "계수 먼저, 문자 나중.",
          "solution": {
            "5x² × 2x³": "10x⁵",
            "18a²b ÷ 3ab": "6a"
          }
        },
        {
          "step": 5,
          "type": "quiz",
          "title": "핵심 퀴즈",
          "items": [
            {
              "q": "3x² × 4x의 값은?",
              "choices": [
                "12x²",
                "12x³",
                "7x²"
              ],
              "answer": 1,
              "feedback_correct": "3×4=12, x²×x=x³",
              "feedback_wrong": "계수와 지수를 따로 계산하자."
            },
            {
              "q": "8a³ ÷ 2a의 값은?",
              "choices": [
                "4a²",
                "6a³",
                "4a³"
              ],
              "answer": 0,
              "feedback_correct": "8÷2=4, a³÷a=a²",
              "feedback_wrong": "계수와 문자를 따로 나눠 봐."
            }
          ]
        }
      ]
    }
  ]
}